#include<stdio.h>
int main(){
    int n,bt[10],wt[10],tat[10];
    float aw=0,at=0;

    printf("n: "); scanf("%d",&n);
    for(int i=0;i<n;i++) scanf("%d",&bt[i]);

    wt[0]=0;
    for(int i=1;i<n;i++)
        wt[i]=wt[i-1]+bt[i-1];

    for(int i=0;i<n;i++){
        tat[i]=wt[i]+bt[i];
        aw+=wt[i]; at+=tat[i];
        printf("P%d WT=%d TAT=%d\n",i+1,wt[i],tat[i]);
    }

    printf("Avg WT=%.2f\nAvg TAT=%.2f",aw/n,at/n);
}
