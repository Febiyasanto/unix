#include <stdio.h>
int main() {
    int n,tq,i,time=0; 
    scanf("%d",&n);
    int bt[n];
    for(i=0;i<n;i++) 
      scanf("%d",&bt[i]);
    printf("Enter tq: "); 
    scanf("%d",&tq);
    for(i=0;i<n;i++){
        if(bt[i]>tq){
            time+=tq;
            bt[i]-=tq;
            i=-1;
        } else {
            time+=bt[i];
            bt[i]=0;
        }
    }
    printf("Total time = %d", time);
}
