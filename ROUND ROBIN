#include<stdio.h>
int main(){
    int n,tq,bt[10],rem[10],wt[10]={0},t=0,done;

    printf("n tq: "); scanf("%d%d",&n,&tq);
    for(int i=0;i<n;i++){ scanf("%d",&bt[i]); rem[i]=bt[i]; }

    do{
        done=1;
        for(int i=0;i<n;i++){
            if(rem[i]>0){
                done=0;
                if(rem[i]>tq){ t+=tq; rem[i]-=tq; }
                else{ t+=rem[i]; wt[i]=t-bt[i]; rem[i]=0; }
            }
        }
    }while(!done);

    for(int i=0;i<n;i++)
        printf("P%d WT=%d\n",i+1,wt[i]);
}
